PORT=3000
HOST=0.0.0.0
NODE_ENV=development
TWINDROP_SIGNALING_URL=http://localhost:3000
TWINDROP_FRONTEND_URL=http://localhost:3000
TWINDROP_FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TWINDROP_LOG_LEVEL=debug
TWINDROP_ROOM_CODE_LENGTH=6
TWINDROP_ROOM_CAPACITY=2
TWINDROP_ROOM_TTL_MS=3600000
TWINDROP_EMPTY_ROOM_TTL_MS=900000
TWINDROP_CLEANUP_INTERVAL_MS=60000
TWINDROP_MAX_HTTP_PAYLOAD_BYTES=16384
TWINDROP_MAX_SOCKET_PAYLOAD_BYTES=24576
TWINDROP_MAX_SIGNAL_PAYLOAD_BYTES=12288
TWINDROP_MAX_FILE_SIZE_BYTES=2147483648
TWINDROP_MAX_FILES_PER_TRANSFER=10
TWINDROP_REQUEST_WINDOW_MS=60000
TWINDROP_ROOM_CREATE_LIMIT=30
TWINDROP_ROOM_CHECK_LIMIT=120
TWINDROP_SOCKET_JOIN_LIMIT=20
TWINDROP_SOCKET_SIGNAL_LIMIT=240
TWINDROP_SOCKET_PATH=/socket.io
TWINDROP_RECONNECT_ATTEMPTS=4
TWINDROP_ALLOWED_CHUNK_SIZES=16384,65536,131072,262144,524288
TWINDROP_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["stun:stun1.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"turn-user","credential":"turn-password"}]
